@{
    ViewData["Title"] = "Access Denied";
}
<div class="container-fluid px-4 py-5">
    <div class="text-center" style="max-width: 480px; margin: 0 auto;">
        <div style="font-size: 4rem; color: var(--sq-danger); margin-bottom: 1rem;">
            <i class="bi bi-shield-x"></i>
        </div>
        <h3 class="fw-bold mb-2">Access Denied</h3>
        <p style="color: var(--sq-muted)">
            You do not have permission to view this page.
        </p>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary mt-2">
            <i class="bi bi-arrow-left me-2"></i>Back to Login
        </a>
    </div>
</div>