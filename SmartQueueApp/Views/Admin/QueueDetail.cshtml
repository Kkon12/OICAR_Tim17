@model SmartQueueApp.Models.ViewModels.AdminQueueDetailViewModel
@{
    ViewData["Title"] = Model.Queue?.Name ?? "Queue Detail";
}

<div class="container-fluid px-4 py-3">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <a asp-action="Queues"
               style="color:var(--sq-muted);text-decoration:none;font-size:0.875rem">
                <i class="bi bi-arrow-left me-1"></i>Back to Queues
            </a>
            <h1 class="page-title mt-1">
                <i class="bi bi-collection me-2 text-primary"></i>@Model.Queue?.Name
            </h1>
            @if (Model.Queue != null)
            {
                <span class="status-@Model.Queue.Status.ToLower()">
                    @Model.Queue.Status
                </span>
            }
        </div>
        @if (Model.Queue != null)
        {
            <a asp-action="CreateCounter"
               asp-route-queueId="@Model.Queue.Id"
               class="btn btn-sq-primary">
                <i class="bi bi-plus-lg me-2"></i>Add Counter
            </a>
        }
    </div>

    @* ── Stats row ────────────────────────────────────────────────────────── *@
    @if (Model.Stats != null)
    {
        var s = Model.Stats;
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-hourglass"></i></div>
                    <div>
                        <div class="stat-value">@s.CurrentlyWaiting</div>
                        <div class="stat-label">Waiting</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
                    <div>
                        <div class="stat-value">@s.CompletedToday</div>
                        <div class="stat-label">Done Today</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon orange"><i class="bi bi-clock"></i></div>
                    <div>
                        <div class="stat-value">
                            @(s.AvgWaitMinutesToday > 0 ? $"{s.AvgWaitMinutesToday}m" : "—")
                        </div>
                        <div class="stat-label">Avg Wait</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-person-badge"></i></div>
                    <div>
                        <div class="stat-value">
                            @(s.AvgServiceMinutesToday > 0 ? $"{s.AvgServiceMinutesToday}m" : "—")
                        </div>
                        <div class="stat-label">Avg Service</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon red"><i class="bi bi-skip-forward"></i></div>
                    <div>
                        <div class="stat-value">@s.SkipRateToday%</div>
                        <div class="stat-label">Skip Rate</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-display"></i></div>
                    <div>
                        <div class="stat-value">@s.OpenCounters/@s.TotalCounters</div>
                        <div class="stat-label">Counters</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Counters table ───────────────────────────────────────────────────── *@
    <div class="sq-card mb-3">
        <h6 class="fw-semibold mb-3">
            <i class="bi bi-display me-2 text-primary"></i>Counters
        </h6>

        @if (Model.Counters.Any())
        {
            <table class="sq-table">
                <thead>
                    <tr>
                        <th>Counter</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Serving</th>
                        <th>Tickets Today</th>
                        <th>Avg Service</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Counters)
                    {
                        var cStat = Model.CounterStats
                        .FirstOrDefault(s => s.CounterId == c.Id);

                        <tr>
                            <td class="fw-semibold">@c.Name</td>

                            <td>
                                <span class="status-@c.Status.ToLower()">
                                    <i class="bi bi-circle-fill me-1"
                                       style="font-size:0.45rem;vertical-align:middle"></i>
                                    @c.Status
                                </span>
                            </td>

                            @* ── Assigned To cell: shows name + inline reassign form ── *@
                            <td>
                                @* Current assignment label *@
                                <div class="mb-1" style="font-size:0.875rem">
                                    @if (!string.IsNullOrEmpty(c.AssignedUserName))
                                    {
                                        <span class="text-success fw-semibold">
                                            <i class="bi bi-person-check me-1"></i>
                                            @c.AssignedUserName
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--sq-muted)">
                                            <i class="bi bi-person-dash me-1"></i>
                                            Unassigned
                                        </span>
                                    }
                                </div>

                                @* Inline reassign dropdown — only shown when there
                        is at least one active Djelatnik to pick from *@
                                @if (Model.AvailableStaff.Any())
                                {
                                    <form asp-action="AssignCounter" method="post"
                                          class="d-flex gap-1 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="CounterId" value="@c.Id" />
                                        <input type="hidden" name="QueueId" value="@Model.Queue!.Id" />

                                        <select name="UserId"
                                                class="form-select form-select-sm"
                                                style="max-width:160px;
                                                       background:var(--sq-surface);
                                                       border-color:var(--sq-border);
                                                       color:var(--sq-text);
                                                       font-size:0.8rem">
                                            <option value="" disabled selected>
                                                — pick staff —
                                            </option>
                                            @foreach (var staff in Model.AvailableStaff)
                                            {
                                                <option value="@staff.Id"
                                                        selected="@(staff.Id == c.AssignedUserId)">
                                                    @staff.FirstName @staff.LastName
                                                </option>
                                            }
                                        </select>

                                        <button type="submit"
                                                class="btn btn-sm btn-sq-primary"
                                                title="Assign selected staff to this counter">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                }
                            </td>

                            <td>
                                @if (c.CurrentTicketNumber.HasValue)
                                {
                                    <span class="fw-bold text-success">
                                        #@c.CurrentTicketNumber
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--sq-muted)">—</span>
                                }
                            </td>

                            <td>@(cStat?.TicketsServedToday ?? 0)</td>

                            <td>
                                @(cStat?.AvgServiceMinutesToday > 0
                                    ? $"{cStat.AvgServiceMinutesToday} min"
                                    : "—")
                            </td>

                            <td>
                                <form asp-action="DeleteCounter" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete @c.Name?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <input type="hidden" name="queueId" value="@Model.Queue!.Id" />
                                    <button class="btn btn-sm btn-danger"
                                            title="Delete counter">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-display"></i>
                <p>No counters yet</p>
                @if (Model.Queue != null)
                {
                    <a asp-action="CreateCounter"
                       asp-route-queueId="@Model.Queue.Id"
                       class="btn btn-sq-primary">
                        Add first counter
                    </a>
                }
            </div>
        }
    </div>

    @* ── Peak hours ───────────────────────────────────────────────────────── *@
    @if (Model.PeakHours?.ByHour.Any() == true)
    {
        <div class="sq-card">
            <h6 class="fw-semibold mb-3">
                <i class="bi bi-graph-up me-2 text-primary"></i>Peak Hours
            </h6>
            <div class="row g-3">
                @if (Model.PeakHours.BusiestHour != null)
                {
                    <div class="col-md-6">
                        <div style="background:rgba(79,142,247,0.08);
                                    border:1px solid rgba(79,142,247,0.2);
                                    border-radius:10px;padding:1rem">
                            <div style="color:var(--sq-muted);font-size:0.8rem">
                                Busiest Hour
                            </div>
                            <div class="fw-bold fs-5">
                                @Model.PeakHours.BusiestHour.HourLabel
                            </div>
                            <div style="color:var(--sq-muted);font-size:0.85rem">
                                @Model.PeakHours.BusiestHour.TicketCount tickets,
                                avg @Model.PeakHours.BusiestHour.AvgWaitMinutes min wait
                            </div>
                        </div>
                    </div>
                }
                @if (Model.PeakHours.BusiestDay != null)
                {
                    <div class="col-md-6">
                        <div style="background:rgba(62,207,142,0.08);
                                    border:1px solid rgba(62,207,142,0.2);
                                    border-radius:10px;padding:1rem">
                            <div style="color:var(--sq-muted);font-size:0.8rem">
                                Busiest Day
                            </div>
                            <div class="fw-bold fs-5">
                                @Model.PeakHours.BusiestDay.DayName
                            </div>
                            <div style="color:var(--sq-muted);font-size:0.85rem">
                                @Model.PeakHours.BusiestDay.TicketCount tickets,
                                avg @Model.PeakHours.BusiestDay.AvgWaitMinutes min wait
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
