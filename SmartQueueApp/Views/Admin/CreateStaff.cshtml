@model SmartQueueApp.Models.ViewModels.CreateStaffViewModel
@{
    ViewData["Title"] = "Add Staff Member";
}

<div class="container-fluid px-4 py-3">
    <div class="page-header">
        <a asp-action="Staff" style="color:var(--sq-muted);text-decoration:none;font-size:0.875rem">
            <i class="bi bi-arrow-left me-1"></i>Back to Staff
        </a>
        <h1 class="page-title mt-2">
            <i class="bi bi-person-plus me-2 text-primary"></i>Add Staff Member
        </h1>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="sq-card">
                @if (Model.ErrorMessage != null)
                {
                    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
                }

                <form asp-action="CreateStaff" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label">First Name</label>
                            <input name="FirstName" value="@Model.FirstName"
                                   class="form-control" placeholder="Ivan" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Last Name</label>
                            <input name="LastName" value="@Model.LastName"
                                   class="form-control" placeholder="Horvat" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input name="Email" type="email" value="@Model.Email"
                               class="form-control"
                               placeholder="ivan@smartqueue.com" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input name="Password" type="password"
                               class="form-control"
                               placeholder="Min. 8 characters" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Role</label>
                        <select name="Role" class="form-select">
                            <option value="Djelatnik" selected>Djelatnik</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-sq-primary">
                            <i class="bi bi-person-plus me-2"></i>Create Account
                        </button>
                        <a asp-action="Staff" class="btn btn-sq-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>