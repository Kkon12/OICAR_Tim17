@model SmartQueueApp.Models.ViewModels.AdminDashboardViewModel
@inject SmartQueueApp.Services.LanguageService Lang
@{
    ViewData["Title"] = SmartQueueApp.Services.T.Dashboard(Lang.IsHr);
    var hr = Lang.IsHr;
}

<div class="container-fluid px-4 py-3">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">
                <i class="bi bi-speedometer2 me-2 text-primary"></i>
                @SmartQueueApp.Services.T.Dashboard(hr)
            </h1>
            <p class="page-subtitle">
                @(hr ? "Pregled sustava u stvarnom vremenu" : "Real-time system overview")
            </p>
        </div>
        <span class="badge bg-success">
            <i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>
            @SmartQueueApp.Services.T.Live(hr)
        </span>
    </div>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        </div>
    }

    @if (Model.Overview != null)
    {
        var o = Model.Overview;

        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-collection"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalWaitingNow</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.WaitingNow(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalServedToday</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.ServedToday(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon orange"><i class="bi bi-clock"></i></div>
                    <div>
                        <div class="stat-value">
                            @o.OverallAvgWaitToday
                            <span style="font-size:1rem">
                                @SmartQueueApp.Services.T.Min(hr)
                            </span>
                        </div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.AvgWait(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-display"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalOpenCounters</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.OpenCounters(hr)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-people"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalDjelatsnici</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.StaffMembers(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-ticket"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalTicketsToday</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.TicketsToday(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon red"><i class="bi bi-skip-forward"></i></div>
                    <div>
                        <div class="stat-value">@o.TotalSkippedToday</div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.SkippedToday(hr)
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon green">
                        <i class="bi bi-collection-fill"></i>
                    </div>
                    <div>
                        <div class="stat-value">
                            @o.ActiveQueues
                            <span style="font-size:1rem">/@o.TotalQueues</span>
                        </div>
                        <div class="stat-label">
                            @SmartQueueApp.Services.T.ActiveQueues(hr)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="sq-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-collection me-2 text-primary"></i>
                    @SmartQueueApp.Services.T.QueueStatus(hr)
                </h6>
                <a asp-action="Queues" class="btn btn-sm btn-sq-ghost">
                    @SmartQueueApp.Services.T.ManageQueues(hr)
                    <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>

            @if (o.QueueBreakdown.Any())
            {
                <table class="sq-table">
                    <thead>
                        <tr>
                            <th>@SmartQueueApp.Services.T.Queue(hr)</th>
                            <th>@SmartQueueApp.Services.T.Status(hr)</th>
                            <th>@SmartQueueApp.Services.T.Waiting(hr)</th>
                            <th>@SmartQueueApp.Services.T.Completed(hr)</th>
                            <th>@SmartQueueApp.Services.T.AvgWait(hr)</th>
                            <th>@SmartQueueApp.Services.T.Counters(hr)</th>
                            <th>@SmartQueueApp.Services.T.SkipRate(hr)</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in o.QueueBreakdown)
                        {
                            <tr>
                                <td class="fw-semibold">@q.QueueName</td>
                                <td>
                                    <span class="status-@q.Status.ToLower()">
                                        <i class="bi bi-circle-fill me-1"
                                           style="font-size:0.45rem;
                                                  vertical-align:middle"></i>
                                        @q.Status
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-semibold
                                        @(q.CurrentlyWaiting > 5 ? "text-warning" : "")">
                                        @q.CurrentlyWaiting
                                    </span>
                                </td>
                                <td>@q.CompletedToday</td>
                                <td>
                                    @if (q.AvgWaitMinutesToday > 0)
                                    {
                                        <span>
                                            @q.AvgWaitMinutesToday
                                            @SmartQueueApp.Services.T.Min(hr)
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--sq-muted)">—</span>
                                    }
                                </td>
                                <td>@q.OpenCounters/@q.TotalCounters open</td>
                                <td>
                                    <span class="@(q.SkipRateToday > 20
                                        ? "text-danger" : "")">
                                        @q.SkipRateToday%
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="QueueDetail"
                                       asp-route-id="@q.QueueId"
                                       class="btn btn-sm btn-sq-ghost">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-collection"></i>
                    <p>@(hr ? "Nema redova" : "No queues found")</p>
                    <a asp-action="CreateQueue" class="btn btn-sq-primary">
                        @SmartQueueApp.Services.T.CreateQueue(hr)
                    </a>
                </div>
            }
        </div>
    }
</div>