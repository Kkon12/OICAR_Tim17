@model SmartQueueApp.Models.ViewModels.DjelatnikDashboardViewModel
@{
    ViewData["Title"] = "Counter Dashboard";
}

<div class="container-fluid px-4 py-3">

    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-display me-2 text-primary"></i>Counter Dashboard
        </h1>
        <p class="page-subtitle">Manage your counter and serve customers</p>
    </div>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.MyCounter == null)
    {
        <div class="sq-card">
            <div class="empty-state">
                <i class="bi bi-display"></i>
                <p class="fw-semibold">No counter assigned</p>
                <p style="color:var(--sq-muted);font-size:0.875rem">
                    Ask your Admin to assign you to a counter.
                </p>
            </div>
        </div>
    }
    else
    {
        var c = Model.MyCounter;
        var isOpen = c.Status == "Open" || c.Status == "Busy";

        <div class="row g-4">

            @* Left — Counter status + controls *@
            <div class="col-lg-4">
                <div class="counter-display @(isOpen ? "open" : "")">

                    @* Counter name + status *@
                    <div class="mb-3">
                        <div style="color:var(--sq-muted);font-size:0.8rem;
                                    text-transform:uppercase;letter-spacing:0.05em">
                            Your Counter
                        </div>
                        <div class="fw-bold fs-4">@c.Name</div>
                        <div class="mt-1">
                            <span class="status-@c.Status.ToLower()">
                                <i class="bi bi-circle-fill me-1"
                                   style="font-size:0.45rem;vertical-align:middle"></i>
                                @c.Status
                            </span>
                        </div>
                    </div>

                    @* Currently serving *@
                    @if (Model.CurrentTicket != null)
                    {
                        <div class="mb-4">
                            <div style="color:var(--sq-muted);font-size:0.8rem">
                                Now Serving
                            </div>
                            <div class="serving-number">
                                #@Model.CurrentTicket.TicketNumber.ToString("D3")
                            </div>
                        </div>
                    }
                    else if (isOpen)
                    {
                        <div class="mb-4" style="color:var(--sq-muted)">
                            <i class="bi bi-hourglass me-1"></i>
                            Ready to call next
                        </div>
                    }

                    @* Open/Close counter *@
                    <div class="d-grid gap-2">
                        @if (!isOpen)
                        {
                            <form asp-action="OpenCounter" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-success w-100 py-2 fw-semibold">
                                    <i class="bi bi-play-fill me-2"></i>Open Counter
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="CloseCounter" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-outline-danger w-100 py-2">
                                    <i class="bi bi-stop-fill me-2"></i>Close Counter
                                </button>
                            </form>
                        }
                    </div>
                </div>

                @* Action buttons for current ticket *@
                @if (Model.CurrentTicket != null && isOpen)
                {
                    <div class="sq-card mt-3">
                        <div class="fw-semibold mb-3" style="font-size:0.875rem;
                             color:var(--sq-muted);text-transform:uppercase">
                            Current Ticket Actions
                        </div>
                        <div class="d-grid gap-2">
                            <form asp-action="CompleteTicket" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId"
                                       value="@Model.CurrentTicket.Id" />
                                <button class="btn btn-success w-100 fw-semibold">
                                    <i class="bi bi-check-lg me-2"></i>
                                    Complete — Served
                                </button>
                            </form>
                            <form asp-action="SkipTicket" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId"
                                       value="@Model.CurrentTicket.Id" />
                                <button class="btn btn-outline-warning w-100">
                                    <i class="bi bi-skip-forward me-2"></i>
                                    Skip — Not Present
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            @* Right — Waiting queue *@
            <div class="col-lg-8">
                <div class="sq-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-semibold mb-0">
                            <i class="bi bi-list-ol me-2 text-primary"></i>
                            Waiting Queue
                            <span class="badge bg-primary ms-2">
                                @Model.WaitingTickets.Count
                            </span>
                        </h6>
                        @* Call next button *@
                        @if (isOpen && Model.WaitingTickets.Any()
                       && Model.CurrentTicket == null)
                        {
                            <form asp-action="CallTicket" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId"
                                       value="@Model.WaitingTickets.First().Id" />
                                <input type="hidden" name="counterId" value="@c.Id" />
                                <button class="btn btn-sq-primary">
                                    <i class="bi bi-megaphone me-2"></i>Call Next
                                </button>
                            </form>
                        }
                    </div>

                    @if (Model.WaitingTickets.Any())
                    {
                        <table class="sq-table">
                            <thead>
                                <tr>
                                    <th>Position</th>
                                    <th>Ticket #</th>
                                    <th>Estimated Wait</th>
                                    <th>Waiting Since</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.WaitingTickets)
                                {
                                    var isFirst = t == Model.WaitingTickets.First();
                                    <tr>
                                        <td>
                                            <span class="fw-bold @(isFirst ? "text-primary" : "")">
                                                #@t.Position
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-bold fs-5
                                                @(isFirst ? "text-primary" : "")">
                                                @t.TicketNumber.ToString("D3")
                                            </span>
                                        </td>
                                        <td>
                                            @if (t.EstimatedWaitMinutes.HasValue)
                                            {
                                                <span>~@t.EstimatedWaitMinutes min</span>
                                            }
                                            else
                                            {
                                                <span style="color:var(--sq-muted)">—</span>
                                            }
                                        </td>
                                        <td style="color:var(--sq-muted);font-size:0.85rem">
                                            @t.CreatedAt.ToString("HH:mm")
                                        </td>
                                        <td>
                                            @if (isOpen && Model.CurrentTicket == null)
                                            {
                                                <form asp-action="CallTicket" method="post"
                                                      style="display:inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ticketId"
                                                           value="@t.Id" />
                                                    <input type="hidden" name="counterId"
                                                           value="@c.Id" />
                                                    <button class="btn btn-sm btn-sq-primary">
                                                        <i class="bi bi-megaphone me-1"></i>Call
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-check-circle"></i>
                            <p>No customers waiting</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* ── SignalR live queue updates ────────────────────────────────────────────────
   Only connects when a counter is assigned. Listens for QueueStatusUpdated
   events pushed by the API whenever any ticket in this queue changes status.
   On any update: reloads the page so the Djelatnik always sees fresh data
   without needing to manually refresh.
   withAutomaticReconnect: silently reconnects if the WebSocket drops.
*@
@if (Model.MyCounter != null)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5179/hubs/queue")
            .withAutomaticReconnect()
            .build();

        connection.on("QueueStatusUpdated", function () {
            // Reload to get fresh queue data from the server.
            // Simple and reliable — avoids partial DOM updates that can
            // leave the UI in an inconsistent state.
            window.location.reload();
        });

        connection.start()
            .then(function () {
                // Join the group for this specific queue so we only receive
                // events relevant to this Djelatnik's counter.
                return connection.invoke("JoinQueueGroup", @Model.MyCounter.QueueId);
            })
            .catch(function (err) {
                // Non-fatal — dashboard still works, just without live updates.
                console.warn("SignalR connection failed:", err);
            });
    </script>
}