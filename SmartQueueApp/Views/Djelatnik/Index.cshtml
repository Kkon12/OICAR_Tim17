@model SmartQueueApp.Models.ViewModels.DjelatnikDashboardViewModel
@{
    ViewData["Title"] = "Counter Dashboard";
}

<div class="container-fluid px-4 py-3">

    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-display me-2 text-primary"></i>Counter Dashboard
        </h1>
        <p class="page-subtitle">Manage your counter and serve customers</p>
    </div>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.MyCounter == null)
    {
        <div class="sq-card">
            <div class="empty-state">
                <i class="bi bi-display"></i>
                <p class="fw-semibold">No counter assigned</p>
                <p style="color:var(--sq-muted);font-size:0.875rem">
                    Ask your Admin to assign you to a counter.
                </p>
            </div>
        </div>
    }
    else
    {
        var c = Model.MyCounter;
        var isOpen = c.Status == "Open" || c.Status == "Busy";

        <div class="row g-4">

            @* ── lijeva  kolona — info o šalteru + gumbi  *@
            <div class="col-lg-4">
                <div class="counter-display @(isOpen ? "open" : "")">

                    
                    <div class="mb-3">

                        @* Red (Queue) *@
                        <div style="color:var(--sq-muted);font-size:0.75rem;
                                            text-transform:uppercase;letter-spacing:0.07em;margin-bottom:2px">
                            Red čekanja
                        </div>
                        <div class="fw-bold fs-5 text-primary mb-2">
                            <i class="bi bi-collection me-1"></i>@c.QueueName
                        </div>

                        @* Šalter (Counter) *@
                        <div style="color:var(--sq-muted);font-size:0.75rem;
                                            text-transform:uppercase;letter-spacing:0.07em;margin-bottom:2px">
                            Vaš šalter
                        </div>
                        <div class="fw-bold fs-4">
                            <i class="bi bi-display me-1"></i>@c.Name
                        </div>

                        @* Status  *@
                        <div class="mt-2">
                            <span class="status-@c.Status.ToLower()">
                                <i class="bi bi-circle-fill me-1"
                                   style="font-size:0.45rem;vertical-align:middle"></i>
                                @c.Status
                            </span>
                        </div>
                    </div>

                    @* Now sErving*@
                    @if (Model.CurrentTicket != null)
                    {
                        <div class="mb-4">
                            <div style="color:var(--sq-muted);font-size:0.8rem">
                                Now Serving
                            </div>
                            <div class="serving-number">
                                #@Model.CurrentTicket.TicketNumber.ToString("D3")
                            </div>
                        </div>
                    }
                    else if (isOpen)
                    {
                        <div class="mb-4" style="color:var(--sq-muted)">
                            <i class="bi bi-hourglass me-1"></i>
                            Ready to call next
                        </div>
                    }

                    @* ── Open / Close counter *@
                    <div class="d-grid gap-2">
                        @if (!isOpen)
                        {
                            <form asp-action="OpenCounter" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-success w-100 py-2 fw-semibold">
                                    <i class="bi bi-play-fill me-2"></i>Otvori šalter
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="CloseCounter" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-outline-danger w-100 py-2">
                                    <i class="bi bi-stop-fill me-2"></i>Zatvori šalter
                                </button>
                            </form>
                        }
                    </div>
                </div>

                @* ── Skip button — Pokazuje se samo za called ticket ,  *@
                @if (Model.CurrentTicket != null && isOpen)
                {
                    <div class="sq-card mt-3">
                        <div class="fw-semibold mb-1" style="font-size:0.875rem;
                                             color:var(--sq-muted);text-transform:uppercase">
                            Trenutni ticket — akcije
                        </div>
                        <div style="color:var(--sq-muted);font-size:0.8rem;margin-bottom:12px">
                            <i class="bi bi-info-circle me-1"></i>
                            Pozivanjem sljedećeg ticketa ovaj se automatski zatvara.
                        </div>
                        <div class="d-grid">
                            <form asp-action="SkipTicket" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId"
                                       value="@Model.CurrentTicket.Id" />
                                <button class="btn btn-outline-warning w-100 fw-semibold">
                                    <i class="bi bi-skip-forward me-2"></i>
                                    Preskoči — nije prisutan
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            @* Desna kolona, lista tiketa u redu*@
            <div class="col-lg-8">
                <div class="sq-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="fw-semibold mb-0">
                                <i class="bi bi-list-ol me-2 text-primary"></i>
                                Red čekanja — @c.QueueName
                                <span class="badge bg-primary ms-2">
                                    @Model.WaitingTickets.Count
                                </span>
                            </h6>
                            <div style="color:var(--sq-muted);font-size:0.8rem;margin-top:3px">
                                <i class="bi bi-display me-1"></i>@c.Name
                            </div>
                        </div>

        
                        @if (isOpen && Model.WaitingTickets.Any())
                        {
                            <form asp-action="CallTicket" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ticketId"
                                       value="@Model.WaitingTickets.First().Id" />
                                <input type="hidden" name="counterId" value="@c.Id" />
                                <button class="btn btn-sq-primary">
                                    <i class="bi bi-megaphone me-2"></i>Pozovi sljedećeg
                                </button>
                            </form>
                        }
                    </div>

                    @if (Model.WaitingTickets.Any())
                    {
                        <table class="sq-table">
                            <thead>
                                <tr>
                                    <th>Pozicija</th>
                                    <th>Ticket #</th>
                                    <th>Procjena čekanja</th>
                                    <th>Čeka od</th>
                                    <th>Akcija</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.WaitingTickets)
                                {
                                    var isFirst = t == Model.WaitingTickets.First();
                                    <tr>
                                        <td>
                                            <span class="fw-bold @(isFirst ? "text-primary" : "")">
                                                #@t.Position
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-bold fs-5 @(isFirst ? "text-primary" : "")">
                                                @t.TicketNumber.ToString("D3")
                                            </span>
                                        </td>
                                        <td>
                                            @if (t.EstimatedWaitMinutes.HasValue)
                                            {
                                                <span>~@t.EstimatedWaitMinutes min</span>
                                            }
                                            else
                                            {
                                                <span style="color:var(--sq-muted)">—</span>
                                            }
                                        </td>
                                        <td style="color:var(--sq-muted);font-size:0.85rem">
                                            @t.CreatedAt.ToString("HH:mm")
                                        </td>
                                        <td>
                                      
                                            @if (isOpen)
                                            {
                                                <form asp-action="CallTicket" method="post"
                                                      style="display:inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ticketId"
                                                           value="@t.Id" />
                                                    <input type="hidden" name="counterId"
                                                           value="@c.Id" />
                                                    <button class="btn btn-sm btn-sq-primary">
                                                        <i class="bi bi-megaphone me-1"></i>Pozovi
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-check-circle"></i>
                            <p>Nema čekanja — red je prazan</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    }
</div>

@* ── SignalR live queue updates ──
    Konekta se kad je counter dodjeljen.Slusa QueueStatusUpdated kojeg
    gura API za svaku promjenu stanja tiketa , call,complete etc.
    JWT token token injektan od servera iz ViewModela 

*@
@if (Model.MyCounter != null)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const token = "@Model.SignalRToken";

        let readyForUpdates = false;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5179/hubs/queue" + (token ? "?access_token=" + token : ""))
            .withAutomaticReconnect()
            .build();

        connection.on("QueueStatusUpdated", function () {
            if (!readyForUpdates) return;
            window.location.reload();
        });

        connection.start()
            .then(function () {
                return connection.invoke("JoinQueueGroup", @Model.MyCounter.QueueId);
            })
            .then(function () {
                // Start accepting updates after a short grace period
                setTimeout(function () { readyForUpdates = true; }, 500);
            })
            .catch(function (err) {
                console.warn("SignalR connection failed:", err);
            });
    </script>
}
