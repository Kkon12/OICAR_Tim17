@model SmartQueueApp.Models.ViewModels.KioskViewModel
@{
    ViewData["Title"] = "Take a Ticket";
    Layout = null;
}
<!DOCTYPE html>
<html lang="hr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartQueue — Take a Ticket</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: radial-gradient(ellipse at 50% 0%, rgba(79,142,247,0.06) 0%, transparent 60%), var(--sq-bg);
        }

        .kiosk-header {
            padding: 2rem;
            text-align: center;
            border-bottom: 1px solid var(--sq-border);
        }

        .kiosk-body {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .queue-card {
            background: var(--sq-surface);
            border: 2px solid var(--sq-border);
            border-radius: 16px;
            padding: 2rem 2.5rem;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, transform 0.2s, background 0.2s;
            width: 100%;
        }

            .queue-card:hover {
                border-color: var(--sq-primary);
                transform: translateY(-4px);
                background: rgba(79,142,247,0.05);
            }

        .queue-icon {
            width: 64px;
            height: 64px;
            background: rgba(79,142,247,0.12);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--sq-primary);
            margin: 0 auto 1rem;
        }

        .queue-name {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--sq-text);
            margin-bottom: 0.5rem;
        }

        .queue-wait {
            font-size: 0.875rem;
            color: var(--sq-muted);
        }

        .kiosk-footer {
            padding: 1.5rem;
            text-align: center;
            border-top: 1px solid var(--sq-border);
            color: var(--sq-muted);
            font-size: 0.8rem;
        }
    </style>
</head>
<body>

    <div class="kiosk-header">
        <i class="bi bi-collection text-primary" style="font-size:2rem"></i>
        <h1 class="fw-bold mt-2 mb-1">SmartQueue</h1>
        <p style="color:var(--sq-muted)">Select a service and take your ticket</p>
    </div>

    <div class="kiosk-body">
        <div style="width:100%;max-width:900px">

            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger text-center">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @Model.ErrorMessage
                </div>
            }

            @if (!Model.ActiveQueues.Any())
            {
                <div class="text-center" style="color:var(--sq-muted)">
                    <i class="bi bi-moon" style="font-size:3rem;opacity:0.3"></i>
                    <p class="mt-3 fs-5">No services available right now</p>
                    <p class="small">Please check back later or ask staff for assistance.</p>
                </div>
            }
            else
            {
                <div class="row g-4 justify-content-center">
                    @foreach (var q in Model.ActiveQueues)
                    {
                        <div class="col-sm-6 col-lg-4">
                            <form asp-action="TakeTicket" asp-controller="Kiosk"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="queueId" value="@q.Id" />
                                <button type="submit" class="queue-card border-0 w-100">
                                    <div class="queue-icon">
                                        <i class="bi bi-person-lines-fill"></i>
                                    </div>
                                    <div class="queue-name">@q.Name</div>
                                    <div class="queue-wait">
                                        @if (q.TotalWaiting == 0)
                                        {
                                            <span class="text-success">
                                                <i class="bi bi-check-circle me-1"></i>
                                                No waiting
                                            </span>
                                        }
                                        else
                                        {
                                            <span>
                                                <i class="bi bi-people me-1"></i>
                                                @q.TotalWaiting waiting
                                            </span>
                                        }
                                    </div>
                                    @if (q.OpenCounters > 0)
                                    {
                                        <div class="mt-2" style="font-size:0.8rem;
                                             color:var(--sq-success)">
                                            <i class="bi bi-display me-1"></i>
                                            @q.OpenCounters counter@(q.OpenCounters != 1 ? "s" : "") open
                                        </div>
                                    }
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="kiosk-footer">
        SmartQueue &copy; 2026 —
        <a href="/auth/login"
           style="color:var(--sq-muted);text-decoration:none">Staff Login</a>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
</body>
</html>