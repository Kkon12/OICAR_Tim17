@inject SmartQueueApp.Services.LanguageService Lang
<!DOCTYPE html>
<html lang="hr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartQueue</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        var role = User.FindFirst("http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value
        ?? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        var firstName = User.FindFirst("FirstName")?.Value ?? "";
        var lastName = User.FindFirst("LastName")?.Value ?? "";
        var hr = Lang.IsHr;
        var isHrCookie = (Context.Request.Cookies["sq_lang"] ?? "en") == "hr";

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
            <div class="container-fluid px-4">

                <a class="navbar-brand fw-bold text-primary"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-collection me-2"></i>SmartQueue
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>
                                    @SmartQueueApp.Services.T.Dashboard(hr)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Queues">
                                    <i class="bi bi-collection me-1"></i>
                                    @SmartQueueApp.Services.T.Queues(hr)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Staff">
                                    <i class="bi bi-people me-1"></i>
                                    @SmartQueueApp.Services.T.Staff(hr)
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Statistics">
                                    <i class="bi bi-bar-chart me-1"></i>
                                    @SmartQueueApp.Services.T.Statistics(hr)
                                </a>
                            </li>
                        }

                        @if (role == "Djelatnik")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Djelatnik" asp-action="Index">
                                    <i class="bi bi-display me-1"></i>
                                    @SmartQueueApp.Services.T.MyCounter(hr)
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">

                        @* ── Language Switcher ── *@
                        <li class="nav-item">
                            <form asp-controller="Language" asp-action="Switch"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl"
                                       value="@Context.Request.Path" />
                                <input type="hidden" name="lang"
                                       value="@(isHrCookie ? "en" : "hr")" />
                                <button type="submit"
                                        class="btn btn-sm px-2 py-1"
                                        style="background:transparent;
                                           border:1px solid var(--sq-border);
                                           color:var(--sq-muted);
                                           border-radius:6px;
                                           font-size:0.8rem;
                                           font-weight:600;
                                           transition:border-color 0.15s,color 0.15s"
                                        onmouseover="this.style.borderColor='var(--sq-primary)';
                                                 this.style.color='var(--sq-primary)'"
                                        onmouseout="this.style.borderColor='var(--sq-border)';
                                                this.style.color='var(--sq-muted)'">
                                    @(isHrCookie ? "🇬🇧 EN" : "🇭🇷 HR")
                                </button>
                            </form>
                        </li>

                        @* ── User Dropdown ── *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                               href="#" data-bs-toggle="dropdown">
                                <div class="rounded-circle bg-primary d-flex align-items-center
                                        justify-content-center text-white fw-bold"
                                     style="width:32px;height:32px;font-size:13px;flex-shrink:0">
                                    @(firstName.Length > 0
                                        ? firstName[0].ToString().ToUpper() : "?")
                                </div>
                                <span class="d-none d-lg-inline">
                                    @firstName @lastName
                                </span>
                                <span class="badge @(role == "Admin"
                                ? "bg-danger" : "bg-primary") d-none d-lg-inline">
                                    @role
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text text-muted small">
                                        @firstName @lastName
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>
                                            @SmartQueueApp.Services.T.Logout(hr)
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    @* Flash Messages *@
    <div class="container-fluid px-4 mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <main>@RenderBody()</main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>